# Jira
JIRA_DOMAIN=yourcompany.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ          # e.g. DEV

# ClickUp
CLICKUP_API_TOKEN=
CLICKUP_TEAM_ID=               # workspace/team ID (visible in ClickUp URL: app.clickup.com/<team_id>/)

# Plane (Jira workspace)
PLANE_API_KEY=
PLANE_WORKSPACE_JIRA=          # workspace slug for Jira mirror
PLANE_PROJECT_JIRA=            # project ID (UUID) for Jira mirror

# Plane (ClickUp workspace)
PLANE_WORKSPACE_CLICKUP=       # workspace slug for ClickUp mirror
PLANE_PROJECT_CLICKUP=         # project ID (UUID) for ClickUp mirror
